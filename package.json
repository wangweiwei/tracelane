{
  "name": "tracelane",
  "version": "0.5.0",
  "description": "Zero-dependency TypeScript Canvas library for full-link trace and user-behavior waterfalls: zoomable time axis, causal tree, sibling folding, virtualized rows.",
  "keywords": [
    "trace",
    "tracing",
    "distributed-tracing",
    "trace-viewer",
    "span-waterfall",
    "waterfall",
    "timeline",
    "timeline-visualization",
    "gantt",
    "flamegraph",
    "causal-tree",
    "observability",
    "apm",
    "opentelemetry",
    "otel",
    "canvas",
    "data-visualization",
    "dataviz",
    "typescript",
    "framework-agnostic",
    "zero-dependency",
    "virtualization"
  ],
  "type": "module",
  "main": "./dist/tracelane.umd.cjs",
  "module": "./dist/tracelane.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/tracelane.js",
      "require": "./dist/tracelane.umd.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "README.zh-CN.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p tsconfig.build.json",
    "build:demo": "vite build --config vite.demo.config.ts",
    "prepublishOnly": "pnpm run build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "version": "node scripts/bump-version.mjs"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "typescript": "^5.6.3",
    "vite": "^6.0.7"
  },
  "packageManager": "pnpm@9.15.0",
  "license": "MIT",
  "author": "wangweiwei",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wangweiwei/tracelane.git"
  },
  "homepage": "https://github.com/wangweiwei/tracelane#readme",
  "bugs": {
    "url": "https://github.com/wangweiwei/tracelane/issues"
  }
}
